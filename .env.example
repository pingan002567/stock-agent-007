# AI 模型配置
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.deepseek.com/v1
WORKBENCH_AI_MODEL=deepseek-chat

# 可选：其他 AI 提供商
# ANTHROPIC_API_KEY=your_claude_key
# GEMINI_API_KEY=your_gemini_key

# 联网搜索（web_search 工具）。默认用 DuckDuckGo（无需 key）。
# 配置任一 key 即自动升级：Tavily 优先，其次 Serper(Google)。
# TAVILY_API_KEY=tvly-xxx     # https://tavily.com （并启用 web_fetch）
# SERPER_API_KEY=xxx          # https://serper.dev